.board-toolbar { display: flex; justify-content: space-between; align-items: center; gap: 1rem; padding: 1rem 0; border: none; background: transparent; margin-bottom: 0.5rem; }
.board-toolbar__start, .board-toolbar__end { display: flex; align-items: center; gap: 1rem; flex-wrap: wrap; }
.board-search-wrap { position: relative; }
.board-filter-select { min-width: 170px; border: none; border-radius: 999px; padding: .6rem 1rem; background: #fff; color: var(--app-muted); font-size: 0.9rem; box-shadow: 0 4px 15px rgba(0,0,0,0.02); outline: none; }
.board-search-wrap i { position: absolute; top: 50%; transform: translateY(-50%); color: var(--app-muted); inset-inline-start: 1.2rem; left: 1.2rem; right: auto; }
