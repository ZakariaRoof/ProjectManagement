@{
    ViewData["Title"] = "Access Denied";
}

<div class="container py-5">
    <div class="card border-0 shadow-sm rounded-4 mx-auto" style="max-width:700px;">
        <div class="card-body p-5 text-center">

            <div class="display-4 text-danger mb-3">
                <i class="bi bi-shield-lock"></i>
            </div>

            <h1 class="h3 mb-3">
                غير مصرح لك بالوصول
            </h1>

            <p class="text-muted mb-4">
                ليس لديك الصلاحيات المطلوبة لعرض هذه الصفحة.
            </p>

            <a asp-controller="MyProjects"
               asp-action="ApprovedProjects"
               class="btn btn-primary">
                العودة إلى المشاريع
            </a>

        </div>
    </div>
</div>