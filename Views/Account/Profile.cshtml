@model ProjectManagementApp.Models.CurrentUser
@inject ProjectManagementApp.Services.ILocalizationService Localization

@{
    ViewData["Title"] = Localization.IsRtl() ? "الملف الشخصي" : "Profile";

    var initials = string.IsNullOrWhiteSpace(Model.EmployeeName)
        ? "U"
        : string.Concat(
            Model.EmployeeName
                .Split(' ', StringSplitOptions.RemoveEmptyEntries)
                .Take(2)
                .Select(x => x[0])
        );
}

<div class="container-fluid">
    <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
        <div class="card-body p-4 p-lg-5">

            <div class="d-flex align-items-center gap-4 flex-wrap">

                <div class="rounded-circle d-inline-flex align-items-center justify-content-center text-white fw-bold"
                     style="width:88px;height:88px;background:linear-gradient(135deg,#1d4ed8,#0f172a);font-size:1.6rem;">
                    @initials
                </div>

                <div>
                    <h2 class="h4 mb-1">@Model.EmployeeName</h2>

                    <div class="text-muted mb-1">
                        @Model.PositionName
                    </div>

                    <div class="text-muted">
                        @(Localization.IsRtl() ? "الرقم الوظيفي" : "Employee code")
                        : @Model.EmployeeCode
                    </div>
                </div>

            </div>

            <hr class="my-4" />

            <div class="row g-4">

                <div class="col-md-4">
                    <div class="p-3 rounded-4 bg-light h-100">

                        <div class="small text-muted mb-2">
                            @(Localization.IsRtl() ? "القسم" : "Department")
                        </div>

                        <div class="fw-semibold">
                            @(Model.DepartmentName ?? "-")
                        </div>

                    </div>
                </div>

                <div class="col-md-4">
                    <div class="p-3 rounded-4 bg-light h-100">

                        <div class="small text-muted mb-2">
                            @(Localization.IsRtl() ? "المنصب" : "Position")
                        </div>

                        <div class="fw-semibold">
                            @(Model.PositionName ?? "-")
                        </div>

                    </div>
                </div>

                <div class="col-md-4">
                    <div class="p-3 rounded-4 bg-light h-100">

                        <div class="small text-muted mb-2">
                            @(Localization.IsRtl() ? "اللغة" : "Language")
                        </div>

                        <div class="fw-semibold">
                            @(Localization.IsRtl() ? "العربية" : "English")
                        </div>

                    </div>
                </div>

            </div>

        </div>
    </div>
</div>