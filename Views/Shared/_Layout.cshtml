@using ProjectManagementApp.Models
@inject ProjectManagementApp.Services.ILocalizationService Localization
@inject ProjectManagementApp.Services.IAuthService AuthService
@inject ProjectManagementApp.Services.IMyProjectsService MyProjectsService
@{
    var isRtl = Localization.IsRtl();
    var lang = Localization.GetCurrentLanguage();
    var currentPath = (Context?.Request?.Path.Value ?? string.Empty).ToLowerInvariant();
    var currentUser = ViewBag.CurrentUser as CurrentUser ?? await AuthService.GetCurrentUserAsync();
    var isAuthenticated = currentUser != null;
    var isTasksPage = currentPath.Contains("/myprojects/tasks");
    var isProjectsPage = currentPath.Contains("/myprojects/approvedprojects") || currentPath.Contains("/myprojects/manage") || currentPath.Contains("/myprojects/ganttchart");
    var isSettingsPage = currentPath.Contains("/settings");
    var isProfilePage = currentPath.Contains("/account/profile");
    var pageTitle = ViewData["Title"]?.ToString() ?? "ProjectManagementApp";
    var returnPath = Context?.Request?.Path.Value ?? "/";

    string T(string fallbackAr, string fallbackEn) => isRtl ? fallbackAr : fallbackEn;
    string GetInitials(string? name)
    {
        if (string.IsNullOrWhiteSpace(name)) return "U";
        return string.Concat(name.Split(' ', StringSplitOptions.RemoveEmptyEntries).Take(2).Select(x => x[0])).ToUpperInvariant();
    }

    var notificationItems = new List<MyProjectsTaskAssignmentItem>();
    if (isAuthenticated)
    {
        try
        {
            var activeUser = currentUser!;
            var dashboard = await MyProjectsService.GetTasksDashboardAsync(activeUser.EmployeeId, activeUser.DepartmentCode, User.IsInRole("Administrator"));
            var today = DateTime.Today;
            notificationItems = dashboard.Assignments
                .Where(x => x.PercentComplete < 100 && x.EndDate.HasValue && x.EndDate.Value.Date < today)
                .OrderBy(x => x.EndDate)
                .Take(5)
                .ToList();
        }
        catch
        {
            notificationItems = new List<MyProjectsTaskAssignmentItem>();
        }
    }
}
<!DOCTYPE html>
<html lang="@lang" dir="@(isRtl ? "rtl" : "ltr")">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@pageTitle</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="https://cdn.datatables.net/1.13.7/css/dataTables.bootstrap5.min.css" />
    <link rel="stylesheet" href="https://cdn.datatables.net/buttons/2.4.2/css/buttons.bootstrap5.min.css" />
    <link href="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/css/select2.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/select2-bootstrap-5-theme@1.3.0/dist/select2-bootstrap-5-theme.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdn.datatables.net/rowgroup/1.4.1/css/rowGroup.bootstrap5.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/ProjectManagementApp.styles.css" asp-append-version="true" />
</head>
<body class="app-shell-body">
    <div class="app-shell">
        <header class="app-topbar border-bottom">
            <div class="container-fluid px-3 px-lg-4">
                <div class="app-topbar-main py-3">
                    <div class="d-flex align-items-center gap-3 flex-grow-1">
                        <a class="app-brand text-decoration-none" asp-controller="MyProjects" asp-action="ApprovedProjects">
                            <span class="app-brand-icon"><i class="bi bi-kanban-fill"></i></span>
                            <span>
                                <strong class="d-block">@T("نظام إدارة المشاريع", "Project Management")</strong>
                                <small>@T("إدارة المراحل والمهام والتنفيذ", "Phases, tasks, and execution")</small>
                            </span>
                        </a>
                    </div>

                    @if (isAuthenticated)
                    {
                        <div class="app-topbar-actions">
                            <div class="d-flex gap-2 me-3">
                                <form method="post" asp-controller="Account" asp-action="ChangeLanguage" class="m-0">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="returnUrl" value="@returnPath" />
                                    <button type="submit" name="language" value="ar" class="btn btn-sm @(isRtl ? "btn-primary" : "btn-outline-secondary")">العربية</button>
                                </form>
                                <form method="post" asp-controller="Account" asp-action="ChangeLanguage" class="m-0">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="returnUrl" value="@returnPath" />
                                    <button type="submit" name="language" value="en" class="btn btn-sm @(!isRtl ? "btn-primary" : "btn-outline-secondary")">English</button>
                                </form>
                            </div>

                            <div class="dropdown">
                                <button class="btn app-icon-btn position-relative" type="button" data-bs-toggle="dropdown" aria-expanded="false">
                                    <i class="bi bi-bell"></i>
                                    @if (notificationItems.Count > 0)
                                    {
                                        <span class="app-notification-badge">@notificationItems.Count</span>
                                    }
                                </button>
                                <div class="dropdown-menu dropdown-menu-end shadow-sm border-0 rounded-4 p-2 app-dropdown-menu">
                                    <div class="px-2 py-2 fw-bold">@T("الإشعارات", "Notifications")</div>
                                    @if (notificationItems.Any())
                                    {
                                        foreach (var item in notificationItems)
                                        {
                                            <a class="dropdown-item rounded-3 py-2" asp-controller="MyProjects" asp-action="Tasks">
                                                <div class="fw-semibold">@item.TaskName</div>
                                                <div class="small text-muted">@item.ProjectName - @T("متأخرة", "Overdue")</div>
                                            </a>
                                        }
                                    }
                                    else
                                    {
                                        <div class="dropdown-item-text text-muted small">@T("لا توجد إشعارات جديدة", "No new notifications")</div>
                                    }
                                </div>
                            </div>

                            <div class="dropdown">
                                <button class="btn app-user-btn" type="button" data-bs-toggle="dropdown" aria-expanded="false">
                                    <span class="app-user-avatar">@GetInitials(currentUser?.EmployeeName)</span>
                                    <span class="app-user-meta d-none d-md-flex">
                                        <strong>@currentUser?.EmployeeName</strong>
                                        <small>@currentUser?.PositionName</small>
                                    </span>
                                    <i class="bi bi-chevron-down small text-muted"></i>
                                </button>
                                <div class="dropdown-menu dropdown-menu-end shadow-sm border-0 rounded-4 p-2 app-dropdown-menu">
                                    <a class="dropdown-item rounded-3" asp-controller="Account" asp-action="Profile">
                                        <i class="bi bi-person-circle me-2"></i>@T("الملف الشخصي", "Profile")
                                    </a>
                                    <a class="dropdown-item rounded-3" asp-controller="Settings" asp-action="Index">
                                        <i class="bi bi-sliders me-2"></i>@T("الإعدادات", "Settings")
                                    </a>
                                    <div class="dropdown-divider"></div>
                                    <form method="post" asp-controller="Account" asp-action="Logout" class="m-0">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="dropdown-item rounded-3 text-danger">
                                            <i class="bi bi-box-arrow-right me-2"></i>@T("تسجيل الخروج", "Sign out")
                                        </button>
                                    </form>
                                </div>
                            </div>
                        </div>
                    }
                </div>

                @if (isAuthenticated)
                {
                    <div class="app-nav-wrap pb-3">
                        <nav class="nav app-nav-tabs flex-nowrap overflow-auto">
                            <a class="nav-link @(isProjectsPage ? "active" : "")" asp-controller="MyProjects" asp-action="ApprovedProjects">
                                <i class="bi bi-folder2-open"></i>
                                <span>@T("المشاريع", "Projects")</span>
                            </a>
                            <a class="nav-link @(isTasksPage ? "active" : "")" asp-controller="MyProjects" asp-action="Tasks">
                                <i class="bi bi-list-check"></i>
                                <span>@T("المهام", "Tasks")</span>
                            </a>
                            <a class="nav-link @(isSettingsPage ? "active" : "")" asp-controller="Settings" asp-action="Index">
                                <i class="bi bi-sliders"></i>
                                <span>@T("الإعدادات", "Settings")</span>
                            </a>
                            <a class="nav-link @(isProfilePage ? "active" : "")" asp-controller="Account" asp-action="Profile">
                                <i class="bi bi-person"></i>
                                <span>@T("الملف الشخصي", "Profile")</span>
                            </a>
                        </nav>
                    </div>
                }
            </div>
        </header>

        @if (isAuthenticated)
        {
            <div class="app-subbar border-bottom">
                <div class="container-fluid px-3 px-lg-4 py-2 d-flex justify-content-between align-items-center flex-wrap gap-2">
                    <div class="app-subbar-title">
                        @if (IsSectionDefined("SubbarTitle"))
                        {
                            @RenderSection("SubbarTitle", required: false)
                        }
                        else
                        {
                            <span class="text-muted small">@T("منصة حديثة لمتابعة المشاريع والمهام والمراحل", "A modern workspace for projects, tasks, and phases")</span>
                        }
                    </div>
                    <div class="app-subbar-actions d-flex gap-2 flex-wrap">
                        @if (IsSectionDefined("SubbarActions"))
                        {
                            @RenderSection("SubbarActions", required: false)
                        }
                    </div>
                </div>
            </div>
        }

        <main class="container-fluid px-3 px-lg-4 py-4">
            @RenderBody()
        </main>
    </div>

    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.7/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.7/js/dataTables.bootstrap5.min.js"></script>
    <script src="https://cdn.datatables.net/buttons/2.4.2/js/dataTables.buttons.min.js"></script>
    <script src="https://cdn.datatables.net/buttons/2.4.2/js/buttons.bootstrap5.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jszip/3.10.1/jszip.min.js"></script>
    <script src="https://cdn.datatables.net/buttons/2.4.2/js/buttons.html5.min.js"></script>
    <script src="https://cdn.datatables.net/buttons/2.4.2/js/buttons.print.min.js"></script>
    <script src="https://cdn.datatables.net/buttons/2.4.2/js/buttons.colVis.min.js"></script>
    <script src="https://cdn.datatables.net/rowgroup/1.4.1/js/dataTables.rowGroup.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
